<header class="site-header">
  <div class="header-container">
    <a href="/" class="logo">Volya<span>Core</span></a>

    <button class="burger-menu-btn" id="burger-btn" aria-label="Відкрити меню">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <div class="header-nav-wrapper" id="header-menu">
      <div class="search-container">
        <div class="search-wrapper">
          <span class="search-icon">🔍</span>
          <input
            type="text"
            id="global-search"
            placeholder="Знайти улюблений проєкт..."
            autocomplete="off"
          />
        </div>
      </div>

      <nav class="navigation">
        <a href="/">Каталог</a>
        <a href="/watchlist" class="nav-link">Мої списки</a>
        <a href="https://t.me/volyacore" target="_blank" class="tg-channel-btn">Телеграм</a>
      </nav>
    </div>

    <button
      id="theme-toggle"
      class="theme-toggle-btn"
      aria-label="Переключити тему"
    >
      <span class="sun-icon">☀️</span>
      <span class="moon-icon">🌙</span>
    </button>
  </div>
</header>

<script>
  function setupHeaderLogic() {
    const toggleBtn = document.getElementById("theme-toggle");
    toggleBtn?.addEventListener("click", () => {
      const currentTheme = document.documentElement.getAttribute("data-theme") || "dark";
      const newTheme = currentTheme === "light" ? "dark" : "light";
      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
    });

    const burgerBtn = document.getElementById("burger-btn");
    const headerMenu = document.getElementById("header-menu");

    if (burgerBtn && headerMenu) {
      burgerBtn.classList.remove("active");
      headerMenu.classList.remove("open");
      document.body.classList.remove("lock-scroll");

      burgerBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        burgerBtn.classList.toggle("active");
        headerMenu.classList.toggle("open");
        document.body.classList.toggle("lock-scroll");
      });

      const navLinks = headerMenu.querySelectorAll("a");
      navLinks.forEach(link => {
        link.addEventListener("click", () => {
          burgerBtn.classList.remove("active");
          headerMenu.classList.remove("open");
          document.body.classList.remove("lock-scroll");
        });
      });
    }
  }

  setupHeaderLogic();
  document.addEventListener("astro:after-swap", setupHeaderLogic);
</script>

