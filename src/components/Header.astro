---
// Шапка — це внутрішній компонент, тому props та повна HTML-структура сторінки тут більше не потрібні!
---

<header class="site-header">
  <div class="header-container">
    <a href="/" class="logo">Volya<span>Core</span></a>

    <button class="burger-menu-btn" id="burger-btn" aria-label="Відкрити меню">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <div class="header-nav-wrapper" id="header-menu">
      <div class="search-container">
        <div class="search-wrapper">
          <span class="search-icon">🔍</span>
          <input
            type="text"
            id="global-search"
            placeholder="Знайти улюблений проєкт..."
            autocomplete="off"
          />
        </div>
      </div>

      <nav class="navigation">
        <a href="/">Каталог</a>
        <a href="/watchlist" class="nav-link">Мої списки</a>
        <a href="https://t.me/volyacore" target="_blank" class="tg-channel-btn">Телеграм</a>
      </nav>
    </div>

    <button
      id="theme-toggle"
      class="theme-toggle-btn"
      aria-label="Переключити тему"
    >
      <span class="sun-icon">☀️</span>
      <span class="moon-icon">🌙</span>
    </button>
  </div>
</header>

<script>
  function setupHeaderLogic() {
    const toggleBtn = document.getElementById("theme-toggle");
    toggleBtn?.addEventListener("click", () => {
      const currentTheme = document.documentElement.getAttribute("data-theme") || "dark";
      const newTheme = currentTheme === "light" ? "dark" : "light";
      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
    });

    const burgerBtn = document.getElementById("burger-btn");
    const headerMenu = document.getElementById("header-menu");

    if (burgerBtn && headerMenu) {
      burgerBtn.classList.remove("active");
      headerMenu.classList.remove("open");
      document.body.classList.remove("lock-scroll");

      burgerBtn.addEventListener("click", (e) => {
        e.stopPropagation(); // Зупиняємо спливання, щоб клік по бургеру не закривав його ж
        burgerBtn.classList.toggle("active");
        headerMenu.classList.toggle("open");
        document.body.classList.toggle("lock-scroll");
      });

      // Закриваємо меню при кліку на будь-яке посилання всередині
      const navLinks = headerMenu.querySelectorAll("a");
      navLinks.forEach(link => {
        link.addEventListener("click", () => {
          burgerBtn.classList.remove("active");
          headerMenu.classList.remove("open");
          document.body.classList.remove("lock-scroll");
        });
      });
    }
  }

  setupHeaderLogic();
  document.addEventListener("astro:after-swap", setupHeaderLogic);
</script>

<style lang="scss">
  .site-header {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.3s ease, border-color 0.3s ease;
    overflow: hidden; /* 🌟 ЗАБОРОНЯЄМО виходити контенту за межі шапки на ПК */
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 15px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 80px; /* 🌟 СКОРОТИЛИ ВІДСТАНЬ ВДВІЧІ для десктопів */
  }

  .logo {
    font-family: "Raleway", sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: var(--text-primary);
    text-decoration: none;
    z-index: 102;
    flex-shrink: 0; /* Щоб логотип не стискався */
    
    span {
      color: #3b82f6;
      text-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
    }
  }

  /* Обгортка для пошуку та навігації */
  .header-nav-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex: 1;
    gap: 10px; /* 🌟 СКОРОТИЛИ ВІДСТАНЬ ВДВІЧІ між пошуком та навігацією */
  }

  .search-container {
    flex: 1;
    max-width: 450px;
    width: 100%;
  }

  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--bg-main);
    border: 2px solid #2563eb;
    border-radius: 50px;
    padding: 2px;
    transition: all 0.3s ease;
    box-shadow: 0 0 15px rgba(37, 99, 235, 0.1);

    .search-icon {
      position: absolute;
      left: 16px;
      font-size: 14px;
    }

    input {
      width: 100%;
      padding: 10px 16px 10px 44px;
      background: transparent;
      border: none;
      color: var(--text-primary);
      font-size: 14px;
      outline: none;
    }

    &:focus-within {
      border-color: #60a5fa;
      box-shadow: 0 0 25px rgba(37, 99, 235, 0.4);
    }
  }

  .theme-toggle-btn {
    background: var(--bg-button);
