    .moon-icon { display: none; }
  }

  /* ==========================================================================
     📱 АДАПТИВНІ СТИЛІ (ПОВНЕ ПРИХОВУВАННЯ МЕНЮ)
     ========================================================================== */
  
  @media (max-width: 820px) {
    .site-header {
      overflow: visible; /* 🌟 Дозволяємо випадання меню на мобільних */
    }

    .header-container {
      padding: 12px 16px;
    }

    .burger-menu-btn {
      display: flex;
    }

    /* 🌟 Виправляємо шторку: тепер вона ПОВНІСТЮ схована і не стирчить */
    .header-nav-wrapper {
      position: fixed;
      top: 0;
      left: -100%; /* 🌟 Ховаємо повністю вліво за межі екрана */
      right: auto;
