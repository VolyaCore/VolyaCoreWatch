    cursor: pointer;
    padding: 10px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    font-size: 16px;
    z-index: 102;
    flex-shrink: 0;

    &:hover {
      transform: scale(1.1);
      border-color: #2563eb;
    }
  }

  .navigation {
    display: flex;
    gap: 25px; /* 🌟 Зменшили проміжок між самими посиланнями */
    align-items: center;
    flex-shrink: 0;

    a {
      color: var(--text-muted);
      text-decoration: none;
