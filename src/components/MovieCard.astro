---
import { Image } from "astro:assets";

const {
  id,
  title,
  enTitle,
  cover,
  status,
  episodesCount,
  country,
  year,
  genres,
  imdbRating,
} = Astro.props;

// Автоматично шукаємо всі картинки в папці src/assets/covers/
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/covers/*.{jpeg,jpg,png,gif,webp}"
);

// Очищаємо назву файлу від зайвих шляхів
let cleanCover = cover ? cover.split("/").pop() || "" : "";
if (cleanCover && !cleanCover.includes(".")) {
  cleanCover += ".jpg";
}

// Будуємо фінальний правильний шлях до картинки
const imagePath = `/src/assets/covers/${cleanCover}`;

// Перетворюємо жанри в рядок для дата-атрибуту фільтрів
const genresString = genres ? genres.join(",") : "";

// Перевіряємо статус для правильного класу плашки
const statusNormalized = status ? status.toLowerCase() : "";
const isOngoing = statusNormalized.includes("онгоінг") || statusNormalized === "ongoing";
---

<a
  href={`/lakorn/${id}`}
  class="movie-card custom-lakorn-card"
  data-title={title ? title.toLowerCase() : ""}
  data-country={country || ""}
  data-year={year || ""}
  data-genres={genresString}
  style="display: flex !important; flex-direction: column !important; justify-content: space-between !important; height: 100% !important; background-color: #0f172a; border-radius: 12px; overflow: hidden; text-decoration: none;"
>
  <div class="cover-wrapper custom-cover-wrapper" style="width: 100% !important; aspect-ratio: 2 / 3 !important; position: relative !important; overflow: hidden !important; background-color: #1e293b;">
    {
      images[imagePath] ? (
        <Image
          src={images[imagePath]()}
          alt={title}
          width={400}
          height={600}
          quality="high"
          loading="lazy"
          style="width: 100% !important; height: 100% !important; object-fit: cover !important; display: block !important;"
        />
      ) : (
        <div class="no-cover-placeholder">Немає обкладинки</div>
      )
    }

    <span class={`status-badge ${isOngoing ? "ongoing" : "completed"}`}>
      {isOngoing ? "Онгоінг" : "Завершено"}
    </span>
    
    {imdbRating && <span class="rating-badge">⭐ {imdbRating}</span>}
  </div>
  
  <div class="card-info" style="padding: 14px 12px !important; display: flex !important; flex-direction: column !important; justify-content: space-between !important; gap: 10px !important; flex-grow: 1 !important;">
    <div class="titles-stack" style="display: flex !important; flex-direction: column !important; gap: 4px !important;">
      <h3 class="movie-title" style="font-size: 14px; font-weight: 600; margin: 0; line-height: 1.3;">{title}</h3>
      {enTitle && <span class="movie-en-title" style="font-size: 11px; color: #64748b; line-height: 1.2;">{enTitle}</span>}
    </div>
    <p class="episodes-count" style="font-size: 12px; color: #94a3b8; margin: 0; margin-top: auto !important;">{episodesCount} серій</p>
  </div>
</a>

<style>
  /* Залишаємо базові інтерактивні стилі для ховерів та тем оформлення */
  .movie-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
    border: 1px solid rgba(99, 102, 241, 0.1);
  }

  .movie-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.15);
    border-color: #6366f1;
  }

  .no-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-size: 13px;
  }

  .status-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    z-index: 10;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  }
  
  .status-badge.ongoing { background-color: #ff9800; color: #000; }
  .status-badge.completed { background-color: #4caf50; color: #fff; }

  .rating-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(4px);
    color: #f59e0b;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    z-index: 10;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .movie-title {
    color: #f8fafc;
    display: -webkit-box;
    -webkit-line-clamp: 2; 
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* СВІТЛА ТЕМА */
  :global([data-theme="light"]) .movie-card { background-color: #7C9BCC !important; border-color: rgba(15, 23, 42, 0.15); }
  :global([data-theme="light"]) .movie-card:hover { border-color: #0f172a; }
  :global([data-theme="light"]) .card-info { background-color: #7C9BCC !important; }
  :global([data-theme="light"]) .movie-title { color: #0f172a !important; }
  :global([data-theme="light"]) .movie-en-title { color: #334155 !important; }
  :global([data-theme="light"]) .episodes-count { color: #1e293b !important; }
</style>