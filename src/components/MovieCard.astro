---
import { Image } from "astro:assets";

const {
  id,
  title,
  cover,
  status,
  episodesCount,
  country,
  year,
  genres,
  imdbRating,
} = Astro.props;

// Автоматично шукаємо всі картинки в папці src/assets/covers/
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/covers/*.{jpeg,jpg,png,gif,webp}"
);

// Очищаємо назву файлу від зайвих шляхів (якщо вони випадково прийшли з JSON)
let cleanCover = cover ? cover.split("/").pop() || "" : "";
if (cleanCover && !cleanCover.includes(".")) {
  cleanCover += ".jpg";
}

// Будуємо фінальний правильний шлях до картинки
const imagePath = `/src/assets/covers/${cleanCover}`;

// Перетворюємо жанри в рядок для дата-атрибуту фільтрів
const genresString = genres ? genres.join(",") : "";

// Перевіряємо статус для правильного класу плашки (валідуємо будь-який регістр)
const statusNormalized = status ? status.toLowerCase() : "";
const isOngoing = statusNormalized.includes("онгоінг") || statusNormalized === "ongoing";
---

<a
  href={`/lakorn/${id}`}
  class="movie-card"
  data-title={title ? title.toLowerCase() : ""}
  data-country={country || ""}
  data-year={year || ""}
  data-genres={genresString}
>
  <div class="cover-wrapper">
    {
      images[imagePath] ? (
        <Image
          src={images[imagePath]()}
          alt={title}
          width={400}
          height={600}
          quality="high"
          loading="lazy"
        />
      ) : (
        <div class="no-cover-placeholder">Немає обкладинки</div>
      )
    }

    <span class={`status-badge ${isOngoing ? "ongoing" : "completed"}`}>
      {isOngoing ? "Онгоінг" : "Завершено"}
    </span>
    
    {imdbRating && <span class="rating-badge">⭐ {imdbRating}</span>}
  </div>
  
  <div class="card-info">
    <h3>{title}</h3>
    <p>{episodesCount} серій</p>
  </div>
</a>

<style>
  .movie-card {
    display: flex;
    flex-direction: column;
    background-color: #0f172a;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    border: 1px solid rgba(99, 102, 241, 0.1);
    position: relative;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
  }

  .movie-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.15);
    border-color: #6366f1;
  }

  /* ФІКС МОБІЛЬНОЇ ВЕРСІЇ ТА ПРОПОРЦІЙ ПОСТЕРУ */
  .cover-wrapper {
    width: 100%;
    /* Замість фіксованих 300px робимо адаптивне співвідношення сторін 2:3 */
    aspect-ratio: 2 / 3; 
    position: relative;
    background-color: #1e293b;
    overflow: hidden;
  }

  .cover-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block;
  }

  .no-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-size: 13px;
    background-color: #1e293b;
  }

  .status-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    z-index: 10;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  }
  
  /* Класи тепер точно збігаються з умовою в Astro-скрипті */
  .status-badge.ongoing {
    background-color: #ff9800;
    color: #000;
  }
  .status-badge.completed {
    background-color: #4caf50;
    color: #fff;
  }

  .rating-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(4px);
    color: #f59e0b;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    z-index: 10;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .card-info {
    padding: 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-grow: 1;
    background-color: #0f172a;
  }

  .card-info h3 {
    font-size: 14px;
    font-weight: 600;
    color: #f8fafc;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* Гарантує однакову висоту текстового блоку для вирівнювання сітки */
    height: 36px; 
  }

  .card-info p {
    font-size: 12px;
    color: #94a3b8;
    margin: 0;
  }
</style>