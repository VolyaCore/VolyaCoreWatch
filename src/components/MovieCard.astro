  ---
const { id, title, cover, status, episodesCount, country, year, genres, imdbRating } = Astro.props;
const genresString = genres ? genres.join(',') : '';
---

<a 
  href={`/lakorn/${id}`} 
  class="movie-card" 
  data-title={title.toLowerCase()}
  data-country={country}
  data-year={year}
  data-genres={genresString}
>
  <div class="cover-wrapper">
    <img src={cover} alt={title} loading="lazy" />
    <span class={`status-badge ${status}`}>
      {status === 'ongoing' ? 'Онгоінг' : 'Завершено'}
    </span>
    {imdbRating && (
      <span class="rating-badge">
        ⭐ {imdbRating}
      </span>
    )}
  </div>
  <div class="card-info">
    <h3>{title}</h3>
    <p>{episodesCount} серій</p>
  </div>
</a>

<style>
  .movie-card {
    display: flex;
    flex-direction: column;
    background-color: #0f172a;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(99, 102, 241, 0.1);
    position: relative; 
  }

  .movie-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.15);
    border-color: #6366f1;
  }

  .cover-wrapper {
    width: 100%;
    height: 300px;
    position: relative;
  }

  .cover-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .status-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    z-index: 10;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  }
  .status-badge.ongoing { background-color: #ff9800; color: #000; }
  .status-badge.completed { background-color: #4caf50; color: #fff; }

  /* Стилі для зірочки оцінки */
  .rating-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(4px);
    color: #f59e0b; /* Золотий колір */
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    z-index: 10;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .card-info {
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .card-info h3 {
    font-size: 16px;
    font-weight: 600;
    color: #f8fafc;
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-info p {
    font-size: 13px;
    color: #94a3b8;
    margin: 0;
  }
</style>