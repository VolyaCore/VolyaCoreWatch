---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCard from "../components/MovieCard.astro";
import lakornsData from "../data/lakorns.json";

// Повертаємо ліміт у 24 штуки для початкового відображення (під пагінацію)
const latestLakorns = lakornsData.slice(0, 24);
---

<MainLayout title="VolyaCore">
  
  <section class="hero-carousel-section">
    <div class="carousel-container">
      <div class="carousel-track" id="carousel-track">
        {
          lakornsData.map((lakorn) => (
            <div class="carousel-slide-wrapper" data-id={lakorn.id}>
              <MovieCard
                id={lakorn.id}
                title={lakorn.title}
                enTitle={lakorn.enTitle}
                cover={lakorn.cover}
                status={lakorn.status}
                episodesCount={lakorn.episodesCount}
                country={lakorn.country}
                year={lakorn.year}
                genres={lakorn.genres}
                imdbRating={lakorn.imdbRating}
              />
            </div>
          ))
        }
      </div>
      
      <button class="carousel-nav-btn prev-btn" id="carousel-prev" aria-label="Попередній">❮</button>
      <button class="carousel-nav-btn next-btn" id="carousel-next" aria-label="Наступний">❯</button>
      
      <div class="carousel-dots" id="carousel-dots"></div>
    </div>
  </section>

  <section class="filters-section">
    <div class="filter-group">
      <label for="filter-country">Країна</label>
      <select id="filter-country">
        <option value="all">Усі країни</option>
        <option value="thailand">Таїланд</option>
        <option value="korea">Південна Корея</option>
        <option value="japan">Японія</option>
        <option value="china">Китай</option>
        <option value="taiwan">Тайвань</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="filter-genre">Жанр</label>
      <select id="filter-genre">
        <option value="all">Усі жанри</option>
        <option value="romance">Романтика</option>
        <option value="drama">Драма</option>
        <option value="comedy">Комедія</option>
        <option value="crime">Кримінал</option>
        <option value="sports">Спорт</option>
        <option value="music">Музика</option>
        <option value="routine">Буденність</option>
        <option value="fantasy">Фентезі</option>
        <option value="action">Бойовик</option>
        <option value="horrors">Жахи</option>
        <option value="supernatural">Надприродне</option>
        <option value="thriller">Триллер</option>
        <option value="mysticism">Містика</option>
        <option value="youth">Юність</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="filter-year">Рік</label>
      <select id="filter-year">
        <option value="all">Усі роки</option>
        <option value="2026">2026</option>
        <option value="2025">2025</option>
        <option value="2024">2024</option>
        <option value="2023">2023</option>
        <option value="2022">2022</option>
      </select>
    </div>
  </section>

  <section class="catalog-section" data-all-lakorns={JSON.stringify(lakornsData)}>
    <h2>Усі релізи</h2>

    <div class="movies-grid" id="catalog-grid">
      {
        latestLakorns.map((lakorn) => (
          <div 
            class="catalog-card-wrapper" 
            data-status={lakorn.status.toUpperCase()}
            data-en-title={lakorn.enTitle ? lakorn.enTitle.toLowerCase() : ""}
          >
            <MovieCard
              id={lakorn.id}
              title={lakorn.title}
              enTitle={lakorn.enTitle}
              cover={lakorn.cover}
              status={lakorn.status}
              episodesCount={lakorn.episodesCount}
              country={lakorn.country}
              year={lakorn.year}
              genres={lakorn.genres}
              imdbRating={lakorn.imdbRating}
            />
          </div>
        ))
      }
    </div>
    <div id="no-results" class="no-results-msg" style="display: none;">
      <p>🔍 На жаль, нічого не знайдено за такими критеріями фільтрації.</p>
    </div>
  </section>
</MainLayout>

<script>
  function initPageFeatures() {
    const catalogGrid = document.getElementById("catalog-grid");
    const catalogSection = document.querySelector(".catalog-section");
    
    // Зберігаємо початковий стан сітки (24 картки), який був згенерований Astro
    let originalStaticHTML = catalogGrid ? catalogGrid.innerHTML : "";

    // Отримуємо ПОВНИЙ масив даних із JSON для всеїдного пошуку
    let allLakorns: any[] = [];
    if (catalogSection) {
      const rawData = catalogSection.getAttribute("data-all-lakorns");
      if (rawData) {
        try { allLakorns = JSON.parse(rawData); } catch(e) {}
      }
    }

    // 1. СОРТУВАННЯ ПОЧАТКОВОГО КАТАЛОГУ (24 картки) НА КЛІЄНТІ
    function shuffleInitialCatalog() {
      if (!catalogGrid) return;
      const cards = Array.from(catalogGrid.querySelectorAll(".catalog-card-wrapper"));
      const ongoingCards = cards.filter(card => card.getAttribute("data-status") === "ОНГОІНГ");
      const completedCards = cards.filter(card => card.getAttribute("data-status") !== "ОНГОІНГ");
      const shuffledCompleted = [...completedCards].sort(() => 0.5 - Math.random());
      
      catalogGrid.innerHTML = "";
      [...ongoingCards, ...shuffledCompleted].forEach(card => catalogGrid.appendChild(card));
      originalStaticHTML = catalogGrid.innerHTML; // Оновлюємо кеш відсортованого стану
    }
    shuffleInitialCatalog();

    // 2. КОНТРОЛЬ ФІЛЬТРІВ КАТАЛОГУ ТА ГЛОБАЛЬНОГО ПОШУКУ
    const searchInput = document.getElementById("global-search") as HTMLInputElement;
    const countrySelect = document.getElementById("filter-country") as HTMLSelectElement;
    const genreSelect = document.getElementById("filter-genre") as HTMLSelectElement;
    const yearSelect = document.getElementById("filter-year") as HTMLSelectElement;
    const noResults = document.getElementById("no-results");

    function filterCatalog() {
      if (!catalogGrid) return;

      const searchQuery = searchInput ? searchInput.value.toLowerCase().trim() : "";
      const selectedCountry = countrySelect ? countrySelect.value : "all";
      const selectedGenre = genreSelect ? genreSelect.value : "all";
      const selectedYear = yearSelect ? yearSelect.value : "all";

      // Якщо пошук та фільтри пусті — повертаємо стандартні 24 картки
      if (!searchQuery && selectedCountry === "all" && selectedGenre === "all" && selectedYear === "all") {
        catalogGrid.innerHTML = originalStaticHTML;
        if (noResults) noResults.style.display = "none";
        return;
      }

      // Якщо користувач шукає, виконуємо пошук по ВСІЙ базі даних (усі релізи й сезони)
      let visibleCount = 0;
      catalogGrid.innerHTML = ""; // Очищаємо сітку для результатів пошуку

      allLakorns.forEach((lakorn) => {
        const titleUa = (lakorn.title || "").toLowerCase();
        const titleEn = (lakorn.enTitle || "").toLowerCase();
        const country = lakorn.country || "";
        const year = (lakorn.year || "").toString();
        const genres = lakorn.genres || [];

        const matchesSearch = searchQuery === "" || titleUa.includes(searchQuery) || titleEn.includes(searchQuery);
        const matchesCountry = selectedCountry === "all" || country === selectedCountry;
        const matchesYear = selectedYear === "all" || year === selectedYear;
        const matchesGenre = selectedGenre === "all" || genres.includes(selectedGenre);

        if (matchesSearch && matchesCountry && matchesYear && matchesGenre) {
          visibleCount++;
          
          // Динамічно створюємо HTML-картку для результату (включаючи 2-гі сезони)
          const wrapper = document.createElement("div");
          wrapper.className = "catalog-card-wrapper";
          wrapper.setAttribute("data-status", lakorn.status ? lakorn.status.toUpperCase() : "");
          wrapper.setAttribute("data-en-title", titleEn);

          const genresAttr = genres.join(",");
          const isOngoing = lakorn.status?.toLowerCase().includes("онгоінг") || lakorn.status?.toLowerCase() === "ongoing";
          const badgeClass = isOngoing ? "ongoing" : "completed";
          const badgeText = isOngoing ? "Онгоінг" : "Завершено";
          const ratingMarkup = lakorn.imdbRating ? `<span class="rating-badge">⭐ ${lakorn.imdbRating}</span>` : '';

          // Розумне очищення обкладинки для генерації шляху
          let cleanCover = lakorn.cover ? lakorn.cover.split("/").pop() : "";
          if (cleanCover && !cleanCover.includes(".")) cleanCover += ".jpg";

          wrapper.innerHTML = `
            <a href="/lakorn/${lakorn.id}" class="movie-card" data-title="${titleUa}" data-country="${country}" data-year="${year}" data-genres="${genresAttr}">
              <div class="cover-wrapper">
                <img src="/src/assets/covers/${cleanCover}" alt="${lakorn.title}" loading="lazy" quality="high" width="400" height="600" />
                <span class="status-badge ${badgeClass}">${badgeText}</span>
                ${ratingMarkup}
              </div>
              <div class="card-info">
                <div class="titles-stack">
                  <h3 class="movie-title">${lakorn.title}</h3>
                  ${lakorn.enTitle ? `<span class="movie-en-title">${lakorn.enTitle}</span>` : ''}
                </div>
                <p class="episodes-count">${lakorn.episodesCount} серій</p>
              </div>
            </a>
          `;
          catalogGrid.appendChild(wrapper);
        }
      });

      if (noResults) {
        noResults.style.display = visibleCount === 0 ? "block" : "none";
      }
    }

    searchInput?.addEventListener("input", filterCatalog);
    countrySelect?.addEventListener("change", filterCatalog);
    genreSelect?.addEventListener("change", filterCatalog);
    yearSelect?.addEventListener("change", filterCatalog);

    // 3. РОБОТА КАРУСЕЛІ (без змін)
    const track = document.getElementById('carousel-track');
    const dotsContainer = document.getElementById('carousel-dots');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    
    if (!track) return;

    const allSlides = Array.from(document.querySelectorAll('.carousel-slide-wrapper'));
    if (allSlides.length === 0) return;

    track.innerHTML = '';
    if (dotsContainer) dotsContainer.innerHTML = '';

    const shuffled = [...allSlides].sort(() => 0.5 - Math.random());
    const selectedSlides = shuffled.slice(0, 7);

    selectedSlides.forEach((slide) => {
      slide.classList.add('carousel-active');
      track.appendChild(slide);
    });

    function getSlidesPerPage() {
      const width = window.innerWidth;
      if (width >= 1200) return 4;
      if (width >= 900) return 3;
      if (width >= 480) return 2;
      return 1;
    }

    let currentIndex = 0;
    let autoSlideInterval: number;

    function buildDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      const slidesPerPage = getSlidesPerPage();
      const maxIndex = Math.max(1, selectedSlides.length - slidesPerPage + 1);

      for (let i = 0; i < maxIndex; i++) {
        const dot = document.createElement('div');
        dot.className = `carousel-dot ${i === currentIndex ? 'active' : ''}`;
        dot.dataset.index = i.toString();
        dotsContainer.appendChild(dot);
      }
    }

    function updateSlider(index: number) {
      const slidesPerPage = getSlidesPerPage();
      const maxIndex = Math.max(1, selectedSlides.length - slidesPerPage + 1);

      if (index >= maxIndex) currentIndex = 0;
      else if (index < 0) currentIndex = maxIndex - 1;
      else currentIndex = index;

      const slideWidthPercentage = 100 / slidesPerPage;
      track!.style.transform = `translateX(-${currentIndex * slideWidthPercentage}%)`;

      const dots = document.querySelectorAll('.carousel-dot');
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });
    }

    function startAutoSlide() {
      stopAutoSlide();
      autoSlideInterval = window.setInterval(() => {
        updateSlider(currentIndex + 1);
      }, 5000);
    }

    function stopAutoSlide() {
      if (autoSlideInterval) clearInterval(autoSlideInterval);
    }

    nextBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      updateSlider(currentIndex + 1);
      startAutoSlide();
    });

    prevBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      updateSlider(currentIndex - 1);
      startAutoSlide();
    });

    dotsContainer?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target && target.classList.contains('carousel-dot')) {
        const idx = parseInt(target.getAttribute('data-index') || '0', 10);
        updateSlider(idx);
        startAutoSlide();
      }
    });

    buildDots();
    updateSlider(currentIndex);
    startAutoSlide();

    window.addEventListener('resize', () => {
      buildDots();
      updateSlider(currentIndex);
    });
  }

  document.addEventListener("DOMContentLoaded", initPageFeatures);
  document.addEventListener("astro:after-swap", initPageFeatures);
</script>

<style is:global>
  .filters-container { display: flex; gap: 20px; width: 100%; }
  .filter-item { flex: 1; }
  @media (max-width: 768px) { .filters-container { flex-direction: column; gap: 12px; } }

  .filters-section {
    display: flex; gap: 20px; background-color: var(--bg-card) !important;
    padding: 20px; border-radius: 12px; border: 1px solid var(--border-color);
    margin-top: 30px; flex-wrap: wrap; transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  [data-theme="light"] .filters-section{ display: flex; gap: 20px; background-color: #7C9BCC !important; }
  .filter-group { display: flex; flex-direction: column; gap: 8px; flex: 1; min-width: 140px; }
  .filter-group label { font-size: 13px; font-weight: 700; color: var(--text-muted) !important; text-transform: uppercase; letter-spacing: 0.5px; }
  .filter-group select { background-color: var(--bg-select) !important; border: 1px solid var(--border-color) !important; color: var(--text-primary) !important; padding: 10px 14px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; outline: none; width: 100%; }
  .filter-group select:focus { border-color: #6366f1 !important; }

  .catalog-section { margin-top: 40px; }
  .catalog-section h2 { font-size: 22px; font-weight: 600; margin-bottom: 25px; border-left: 4px solid #6366f1; padding-left: 12px; color: var(--text-primary) !important; }
  
  .catalog-card-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  
  .movies-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
    gap: 25px; 
  }
  
  @media (max-width: 600px) {
    .movies-grid { 
      grid-template-columns: repeat(2, 1fr) !important; 
      gap: 12px; 
    }
  }

  .no-results-msg { text-align: center; padding: 40px; color: var(--text-muted); font-size: 16px; background-color: var(--bg-card); border-radius: 12px; border: 1px solid var(--border-color); }
  
  .movie-card { 
    width: 100%; 
    height: 100%;
    display: flex;
    flex-direction: column;
    background-color: var(--bg-card) !important; 
    border: 1px solid var(--border-color) !important; 
    border-radius: 12px;
    overflow: hidden;
    box-sizing: border-box;
    transition: background-color 1s ease, border-color 1s ease !important; 
  }
  
  .movie-card img, 
  .movie-card .card-cover img, 
  .carousel-slide-wrapper img {
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 2 / 3 !important;
    object-fit: cover !important;
    display: block;
    border-radius: 8px 8px 0 0;
  }

  .movie-card h3, .movie-card .movie-title, .movie-card a { color: var(--text-primary) !important; font-size: 14px; margin: 8px 0 4px 0; line-height: 1.3; }
  .movie-card p, .movie-card .movie-episodes { color: var(--text-muted) !important; font-size: 12px; }

  .hero-carousel-section {
    width: 100%;
    margin: 1.5rem auto;
    box-sizing: border-box;
    padding: 0 10px;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .carousel-slide-wrapper {
    box-sizing: border-box;
    display: none;
    flex: 0 0 calc(25% - 12px); 
  }

  @media (max-width: 1200px) {
    .carousel-slide-wrapper { flex: 0 0 calc(33.333% - 11px); }
  }
  @media (max-width: 900px) {
    .carousel-slide-wrapper { flex: 0 0 calc(50% - 8px); }
  }
  @media (max-width: 480px) {
    .carousel-slide-wrapper { flex: 0 0 calc(50% - 8px); }
  }
  
  .carousel-slide-wrapper.carousel-active {
    display: block;
  }

  .carousel-slide-wrapper .movie-card {
    width: 100% !important;
    margin: 0 !important;
  }

  .carousel-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    backdrop-filter: blur(6px);
    z-index: 10;
  }
  @media (max-width: 600px) {
    .carousel-nav-btn { width: 32px; height: 32px; font-size: 0.8rem; }
  }
  .carousel-nav-btn:hover { background-color: #6366f1; border-color: #6366f1; transform: translateY(-50%) scale(1.05); }
  .prev-btn { left: 5px; }
  .next-btn { right: 5px; }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 15px;
  }
  
  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  [data-theme="light"] .carousel-dot { background: rgba(0, 0, 0, 0.15); }
  
  .carousel-dot.active {
    background: #6366f1;
    width: 20px;
    border-radius: 4px;
  }
</style>